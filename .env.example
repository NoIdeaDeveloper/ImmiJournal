# ImmiJournal — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Base URL of your Immich server's API endpoint (must end with /api)
IMMICH_BASE_URL=http://192.168.1.180:8080/api

# Immich API key (Immich → Account Settings → API Keys)
IMMICH_API_KEY=your_immich_api_key_here

# ---------------------------------------------------------------------------
# Optional — Security
# ---------------------------------------------------------------------------

# Restrict access with a password (minimum 8 characters recommended).
# When set, the app shows a login page and issues a 30-day session cookie.
# Leave blank to disable authentication (open to anyone on your network).
# APP_PASSWORD=your_strong_password_here

# Set to "true" when ImmiJournal is served over HTTPS (e.g. behind a reverse
# proxy with SSL termination). Enables the Secure flag on session cookies.
# Leave as "false" for plain HTTP on a local network.
SECURE_COOKIES=false

# ---------------------------------------------------------------------------
# Optional — Storage
# ---------------------------------------------------------------------------

# Path to the SQLite database file inside the container.
# Default: /data/immijournal.db (mounted via Docker volume)
# DATABASE_PATH=/data/immijournal.db

# Directory for database backups. Defaults to a "backups/" subdirectory
# alongside DATABASE_PATH. Set to a separate volume path if you want backups
# isolated from the main data volume.
# BACKUP_PATH=/data/backups

# Directory for the Immich thumbnail/preview disk cache.
# Defaults to a system temp directory. Override to persist across restarts
# or to control disk usage location.
# CACHE_DIR=/data/cache

# ---------------------------------------------------------------------------
# Optional — Docker / Unraid File Permissions
# ---------------------------------------------------------------------------

# Run the container process as this user/group (for file ownership on the
# host volume). Find your IDs with: id
# Defaults: 99/100 (nobody/users) — works for most Unraid setups.
# PUID=99
# PGID=100
